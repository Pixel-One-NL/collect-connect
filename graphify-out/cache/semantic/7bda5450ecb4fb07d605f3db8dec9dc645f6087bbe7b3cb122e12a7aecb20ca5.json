{"nodes": [{"id": "plans_quick_island_zip_timeout_fix", "label": "LDraw ZIP Download Timeout Fix Plan (quick-island)", "file_type": "document", "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_quick_island_streaming_download_rationale", "label": "Streamed ZIP Download Rationale", "file_type": "rationale", "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": "L13", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Http::get() default 30s timeout and full in-memory buffering of response body fails for ~700MB LDraw archives. Fix: use Http sink() to stream bytes directly to a tmpfile, with generous overall timeout (600s default) + short connectTimeout (15s default). Both configurable via config/rebrickable.php env vars."}, {"id": "plans_quick_island_chunked_attach_rationale", "label": "Chunked Stream-Attach Rationale for ImportColorLdrawImagesJob", "file_type": "rationale", "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": "L163", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Buffering all matched PNG bytes for a color into $pngsByStem before attaching uses high memory for large archives. Refactor: process ZIP entries in bounded batches (attachBatchSize=200), resolving part ids with one whereIn per batch and attaching immediately, then clearing the buffer."}, {"id": "plans_quick_island_media_conversions", "label": "Part-Color Media Conversions Plan (preview/medium/large)", "file_type": "document", "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": "L410", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_quick_island_media_conversion_rationale", "label": "Media Conversion Sizing Rationale", "file_type": "rationale", "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": "L427", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Three width-based Fit::Contain variants: preview(150x150), medium(350x350), large(500x500). large reduced from 600 to 500 to match actual LDraw render size. 'medium' is new. Conversion names preserved so existing consumers (ProductResource, ProductSearchResource, CartService) need no changes."}, {"id": "concept_partcolor_media_collections", "label": "PartColor Media Collections (ldraw / bricqer / image)", "file_type": "concept", "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "plans_quick_island_zip_timeout_fix", "target": "plans_quick_island_streaming_download_rationale", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": "L13", "weight": 1.0}, {"source": "plans_quick_island_zip_timeout_fix", "target": "plans_quick_island_chunked_attach_rationale", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": "L163", "weight": 1.0}, {"source": "plans_quick_island_zip_timeout_fix", "target": "concept_ldraw_image_pipeline", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": null, "weight": 0.95}, {"source": "plans_quick_island_media_conversions", "target": "plans_quick_island_media_conversion_rationale", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": "L427", "weight": 1.0}, {"source": "plans_quick_island_media_conversions", "target": "concept_partcolor_media_collections", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": null, "weight": 0.95}, {"source": "plans_quick_island_zip_timeout_fix", "target": "plans_cosmic_engine_ldraw_import_plan", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": ".kilo/plans/1780343168016-quick-island.md", "source_location": null, "weight": 0.85}], "hyperedges": []}
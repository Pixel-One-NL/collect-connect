{"nodes": [{"id": "plans_cosmic_engine_ldraw_import_plan", "label": "LDraw Part-Color Image Import Plan (cosmic-engine)", "file_type": "document", "source_file": ".kilo/plans/1780229984015-cosmic-engine.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plans_cosmic_engine_importcolorldrawimagesjob_concept", "label": "ImportColorLdrawImagesJob (planned per-color job)", "file_type": "rationale", "source_file": ".kilo/plans/1780229984015-cosmic-engine.md", "source_location": "L124", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One queued job per color keeps memory bounded and enables parallelism. Each job streams a per-color ZIP from Rebrickable CDN, extracts PNG filenames by stem (matching parts.rebrickable_id), and attaches to a new ldraw media collection on PartColor. Freshness window of 7 days (constant) prevents redundant re-downloads."}, {"id": "plans_cosmic_engine_ldraw_collection_design", "label": "LDraw Media Collection Design", "file_type": "rationale", "source_file": ".kilo/plans/1780229984015-cosmic-engine.md", "source_location": "L37", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A new dedicated 'ldraw' media collection (separate from existing 'image' collection) is added to PartColor so future image sources can coexist. Freshness tracked via nullable ldraw_images_imported_at timestamp on colors table."}, {"id": "plans_cosmic_engine_retrievezipentriesfromurl_concept", "label": "retrieveZipEntriesFromUrl Contract Extension", "file_type": "rationale", "source_file": ".kilo/plans/1780229984015-cosmic-engine.md", "source_location": "L89", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Extends RebrickableDownloader contract to yield named binary ZIP entries one at a time, keeping memory bounded. A 404 for a missing color ZIP is expected and treated as empty (no error thrown)."}, {"id": "concept_ldraw_image_pipeline", "label": "LDraw Image Import Pipeline", "file_type": "concept", "source_file": ".kilo/plans/1780229984015-cosmic-engine.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "plans_cosmic_engine_ldraw_import_plan", "target": "plans_cosmic_engine_importcolorldrawimagesjob_concept", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".kilo/plans/1780229984015-cosmic-engine.md", "source_location": "L124", "weight": 1.0}, {"source": "plans_cosmic_engine_ldraw_import_plan", "target": "plans_cosmic_engine_ldraw_collection_design", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".kilo/plans/1780229984015-cosmic-engine.md", "source_location": "L37", "weight": 1.0}, {"source": "plans_cosmic_engine_ldraw_import_plan", "target": "plans_cosmic_engine_retrievezipentriesfromurl_concept", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".kilo/plans/1780229984015-cosmic-engine.md", "source_location": "L89", "weight": 1.0}, {"source": "plans_cosmic_engine_ldraw_import_plan", "target": "concept_ldraw_image_pipeline", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".kilo/plans/1780229984015-cosmic-engine.md", "source_location": null, "weight": 1.0}], "hyperedges": []}
# General application settings
APP_NAME="Zenchef Bookings"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Locale settings
APP_LOCALE=nl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance driver
APP_MAINTENANCE_DRIVER=file

# Password hasing settings
BCRYPT_ROUNDS=12

# Logging settings
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database settings
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=password

# Session settings
SESSION_DRIVER=database

# Broadcast settings
BROADCAST_CONNECTION=log

# Filesystem settings
FILESYSTEM_DISK=local

# Queue settings
QUEUE_CONNECTION=database

# Cache settings
CACHE_STORE=database
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

# Mail settings
MAIL_MAILER=log
MAIL_SCHEME=smtp
MAIL_HOST=mailpit
MAIL_PORT=2525
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Assets settings
VITE_APP_NAME="${APP_NAME}"
ASSET_URL="${APP_URL}"

# Scout
SCOUT_DRIVER=typesense
TYPESENSE_API_KEY=masterKey
TYPESENSE_HOST=localhost

# Rebrickable
REBRICKABLE_API_KEY=

# Bricqer
BRICQER_DOMAIN=
BRICQER_API_KEY=
